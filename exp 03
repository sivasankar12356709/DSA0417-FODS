import numpy as np

# Columns: Bedrooms, Square_Feet, Sale_Price
house_data = np.array([
    [3, 1500, 200000],
    [5, 2500, 350000],
    [4, 1800, 250000],
    [6, 3000, 450000],
    [2, 1200, 150000]
])

# Filter houses with more than 4 bedrooms
filtered_houses = house_data[house_data[:,0] > 4]

# Calculate average sale price
average_price = np.mean(filtered_houses[:,2])

print("Average Sale Price of Houses with >4 Bedrooms:", average_price)
