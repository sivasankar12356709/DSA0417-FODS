import pandas as pd

data = {
    'product': ['A','B','A','C','B','A','D','E','B','C'],
    'quantity': [5,3,2,4,6,7,2,1,3,5]
}

sales_data = pd.DataFrame(data)

top_products = sales_data.groupby('product')['quantity'].sum().sort_values(ascending=False).head(5)

print("Top 5 Most Sold Products:")
print(top_products)
